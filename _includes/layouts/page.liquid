---
layout: base
---
<main
  data-pagefind-body
  id="top"
  class="flex-1 prose prose-sm md:prose-base w-full max-w-4xl mx-auto xl:my-8"
>
  <!-- Hero Section -->
  {% render 'hero',
    title: title,
    description: description,
    date: date,
    modified: modified,
    banner: banner,
    cover: cover,
    page: page,
    collections: collections
  %}
  <div class="bg-base-100 text-base-content p-6">
    {% if needsUpdate %}
      <div class="callout" data-callout="bug">
        <div class="callout-title">
          <div class="callout-title-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-bug"
            >
              <path d="m8 2 1.88 1.88"></path><path d="M14.12 3.88 16 2"></path><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"></path><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"></path><path d="M12 20v-9"></path><path d="M6.53 9C4.6 8.8 3 7.1 3 5"></path><path d="M6 13H2"></path><path d="M3 21c0-2.1 1.7-3.9 3.8-4"></path><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"></path><path d="M22 13h-4"></path><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"></path>
            </svg>
          </div>
          <div class="callout-title-inner">Awaiting Update</div>
        </div>
        <div class="callout-content">
          <p>
            This note is marked for an update. That means the content is either incompleted or outdated, but the link is
            kept for reference and cross-linking.
          </p>
        </div>
      </div>
    {% endif %}
    <!-- Page Content -->
    {{ content }}

    <!-- Backlinks -->
    {% if backlinks.length > 0 %}
      <h2>Backlinks</h2>
      <ul>
        {% for link in backlinks %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
    <div class="not-prose">
      <!-- Breadcrumbs -->
      {% assign prefix = page.fileSlug | append: '.' %}
      {% assign crumbs = collections.all
        | where_exp: 'item', 'item.fileSlug != page.fileSlug and item.fileSlug contains prefix'
      %}

      {% if crumbs.size == 0 %}
        <div class="flex w-full flex-col">
          <div class="divider divider-primary"></div>
        </div>
        {% render 'breadcrumbs', page: page, collections: collections %}
      {% endif %}
    </div>
  </div>

  <!-- Children -->
  {% assign navTree = collections.all | eleventyNavigation | sortNavTree %}
  {% assign current = navTree | navFind: eleventyNavigation.key %}
  {% if current.children.size > 0 %}
    <div class="not-prose w-full max-w-7xl mx-auto mb-8 px-6" data-pagefind-ignore>
      <h2 class="text-center text-3xl font-bold m-8">Children</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {% for entry in current.children %}
          {% assign img = entry.data.cover | default: entry.data.banner %}
          {% if img %}
            <div class="card bg-base-100 image-full w-full shadow-sm">
              <figure>
                {% image img, entry.title %}
              </figure>
              <div class="card-body">
                <h2 class="card-title">{{ entry.title }}</h2>
                <p>{{ entry.data.description }}</p>
                <div class="card-actions justify-end">
                  <a href="{{ entry.url }}" class="btn btn-soft btn-secondary">Read More</a>
                </div>
              </div>
            </div>
          {% else %}
            <div class="card bg-secondary text-secondary-content w-full">
              <div class="card-body">
                <h2 class="card-title">{{ entry.title }}</h2>
                <p>{{ entry.data.description }}</p>
                <div class="card-actions justify-end">
                  <a href="{{ entry.url }}" class="btn btn-soft btn-secondary">Read More</a>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</main>

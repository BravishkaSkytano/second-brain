---
layout: base
---
<article
  data-pagefind-body
  class="mx-auto format lg:format-lg dark:format-invert format-red p-6 sm:bg-neutral-primary-soft sm:shadow-xs sm:border sm:border-default"
>
  {% if needsUpdate %}
    <div class="callout" data-callout="bug">
      <div class="callout-title">
        <div class="callout-title-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-bug"
          >
            <path d="m8 2 1.88 1.88"></path><path d="M14.12 3.88 16 2"></path><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"></path><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"></path><path d="M12 20v-9"></path><path d="M6.53 9C4.6 8.8 3 7.1 3 5"></path><path d="M6 13H2"></path><path d="M3 21c0-2.1 1.7-3.9 3.8-4"></path><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"></path><path d="M22 13h-4"></path><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"></path>
          </svg>
        </div>
        <div class="callout-title-inner">Awaiting Update</div>
      </div>
      <div class="callout-content">
        <p>
          This note is marked for an update. That means the content is either incompleted or outdated, but the link is
          kept for reference and cross-linking.
        </p>
      </div>
    </div>
  {% endif %}
  <!-- Page Content -->
  {{ content }}
  {% if backlinks.length > 0 %}
    <!-- Backlinks -->
    <div class="callout" data-callout="summary">
      <div class="callout-title">
        <div class="callout-title-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-list"
          >
            <line x1="8" x2="21" y1="6" y2="6"></line><line x1="8" x2="21" y1="12" y2="12"></line><line x1="8" x2="21" y1="18" y2="18"></line><line x1="3" x2="3.01" y1="6" y2="6"></line><line x1="3" x2="3.01" y1="12" y2="12"></line><line x1="3" x2="3.01" y1="18" y2="18"></line>
          </svg>
        </div>
        <div class="callout-title-inner">Linking here</div>
      </div>
      <div class="callout-content mt-4">
        <ul class="space-y-1 text-body list-disc list-inside">
          {% for link in backlinks %}
            <li>
              <a href="{{ link.url }}" class="font-medium text-fg-brand hover:underline">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  {% endif %}
  <div class="not-format">
    {% if tags and index != true %}
      <div class="flex flex-col space-y-4 sm:flex-row sm:justify-center items-center sm:space-y-0 md:space-x-4 mt-4">
        {% for tag in tags %}
          <a
            href="/{{ tag }}/"
            class="text-fg-brand bg-neutral-primary border border-brand hover:bg-brand hover:text-white focus:ring-4 focus:ring-brand-subtle font-medium leading-5 text-xs px-3 py-1.5 focus:outline-none"
          >
            {{ tag }}
          </a>
        {% endfor %}
      </div>
    {% endif %}
    <div class="mt-5 text-center">
      <a
        href="/"
        class="inline-flex items-center  text-white bg-brand hover:bg-brand-strong box-border border border-transparent focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 text-sm px-4 py-2.5 focus:outline-none"
      >
        <svg
          class="w-4 h-4 me-1.5 -ms-0.5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="none"
          viewBox="0 0 24 24"
        >
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12l4-4m-4 4 4 4"/>
        </svg>

        Back Home
      </a>
    </div>
  </div>
</article>

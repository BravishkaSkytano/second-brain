{% for entry in collection reversed %}
  <div class="break-inside-avoid-column mb-5 bg-neutral-primary-soft block max-w-sm border border-default rounded-base shadow-xs">
    <a href="{{ entry.url }}">
      {% assign img = entry.data.cover | default: entry.data.banner %}
      {% assign title = entry.data.title | default: entry.page.fileSlug %}
      {% if img %}
        {% image img, title, "rounded-t-base" %}
      {% endif %}
      <div class="p-6">
        <h5 class="my-2 text-2xl font-semibold tracking-tight text-heading">
          {{ title }}
        </h5>
        {% if entry.date %}
          <p class="mb-2 text-sm opacity-70">{{ entry.date | date: '%a, %b %d, %Y' }}</p>
        {% endif %}
        <p class="text-body">
          {{ entry.data.description }}
        </p>
      </div>
    </a>
  </div>
{% endfor %}
